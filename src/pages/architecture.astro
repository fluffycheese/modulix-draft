---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Modulix Architecture & Technology Stack",
  "description": "Deep-dive into the technical implementation of the Modulix platform, including the Dual-Stack Hydration model and Canopy security baseline."
};
---

<BaseLayout
  title="Platform Architecture & Technical Specifications - Modulix"
  description="Discover the underlying architecture of Modulix. Learn about our Dual-Stack Hydration engine, Canopy security baseline, and local AI agent pipelines."
  schema={schema}
>
  <div class="architecture-page">
    <!-- Header -->
    <div class="header-container">
      <div class="badge">Technical Blueprint</div>
      <h1>The Technology behind the <span class="gradient-text">No-Drift Promise</span></h1>
      <p class="subtitle">
        Modulix translates technology-neutral declarations of intent into hardened, platform-specific configurations.
      </p>
    </div>

    <!-- Dual Stack Hydration -->
    <section class="section-block">
      <div class="grid-layout">
        <div class="visual-pane">
          <div class="flow-diagram glass-card" aria-hidden="true">
            <div class="flow-node node-start">YAML Blueprint</div>
            <div class="flow-arrow">▼</div>
            <div class="flow-node node-process">Modulix Hydration Adapter</div>
            <div class="flow-split">
              <div class="split-branch">
                <div class="flow-arrow">▼</div>
                <div class="flow-node node-end end-cyan">NixOS Module</div>
              </div>
              <div class="split-branch">
                <div class="flow-arrow">▼</div>
                <div class="flow-node node-end end-blue">Docker Compose</div>
              </div>
            </div>
          </div>
        </div>
        <div class="text-pane">
          <h2>The Dual-Stack Hydration Model</h2>
          <p>
            Traditional infrastructure setups are hardcoded for specific operating systems, locking you into a single vendor's paradigm. Modulix decouples intent from implementation.
          </p>
          <p>
            Using <strong>YAML Blueprints</strong> as the single source of truth, our platform automatically generates configuration files for two distinct stacks:
          </p>
          <ul>
            <li><strong>Standard Tier (Debian + Docker Swarm)</strong>: Low-overhead, highly familiar container orchestration suitable for standard business workloads.</li>
            <li><strong>Enterprise Tier (NixOS)</strong>: Declarative, immutable OS profiles where the entire operating system is compiled from Git declarations. Perfect for strict compliance.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Canopy Hardening Baseline -->
    <section class="section-block dark-bg">
      <div class="section-intro">
        <h2>The Canopy Hardening Baseline</h2>
        <p>Every node deployed by Modulix conforms to our strict, non-negotiable security baseline.</p>
      </div>

      <div class="card-grid">
        <div class="glass-card spec-card">
          <div class="spec-icon">🔑</div>
          <h3>Access Control</h3>
          <p>Strictly SSH-key authentication only. <code>PasswordAuthentication no</code> and <code>PermitRootLogin no</code> are globally enforced at the OS level.</p>
        </div>
        <div class="glass-card spec-card">
          <div class="spec-icon">🛡️</div>
          <h3>Network Security</h3>
          <p>A default-deny firewall policy. Only explicit ports (e.g., SSH, HTTP, HTTPS) are exposed, preventing accidental exposure of internal database ports.</p>
        </div>
        <div class="glass-card spec-card">
          <div class="spec-icon">⚙️</div>
          <h3>Automated Upgrades</h3>
          <p>Unattended OS upgrades (Debian) and automated rebuild schedules (NixOS) are applied out-of-the-box to ensure security patches are applied immediately.</p>
        </div>
        <div class="glass-card spec-card">
          <div class="spec-icon">👤</div>
          <h3>Least Privilege</h3>
          <p>All core services and containers are configured to run as unprivileged users (e.g., the <code>canopy</code> user) to isolate the kernel in the event of an application vulnerability.</p>
        </div>
      </div>
    </section>

    <!-- The Autonomous Factory -->
    <section class="section-block">
      <div class="grid-layout reversed">
        <div class="visual-pane">
          <div class="agent-graphic glass-card" aria-hidden="true">
            <div class="agent-ring">
              <div class="agent-core">AI</div>
              <div class="agent-node a-n1">Transpiler</div>
              <div class="agent-node a-n2">Validator</div>
              <div class="agent-node a-n3">Self-Healer</div>
            </div>
          </div>
        </div>
        <div class="text-pane">
          <h2>The AI Autonomous Factory</h2>
          <p>
            Supporting two distinct OS platforms increases R&D overhead—the "Complexity Tax." Modulix resolves this tax through specialized local AI agents:
          </p>
          <div class="agent-list">
            <div class="agent-item">
              <strong>1. The Transpiler Agent</strong>
              <p>Autonomously translates standard Docker Compose configurations into equivalent, optimized NixOS declarations, preserving environment parity.</p>
            </div>
            <div class="agent-item">
              <strong>2. The QA Validator Agent</strong>
              <p>Spins up temporary "shadow" VMs in our Proxmox clusters to test all hydrated configurations, running automated functional tests before human code approval.</p>
            </div>
            <div class="agent-item">
              <strong>3. The Self-Healer Agent</strong>
              <p>Monitors system state in production, checking active files against declared Git blueprints. If configuration drift is detected, it triggers a rebuild-to-state event.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Telemetry & Secrets -->
    <section class="section-block last-block">
      <div class="glass-card detail-banner">
        <h2>Sovereign Secret & Telemetry Fabrics</h2>
        <div class="detail-grid">
          <div>
            <h3>Sops & age Encryption</h3>
            <p>
              We enforce zero-plaintext credentials in Git. Client secrets are encrypted using SOPS and age keys, decrypting on target nodes only at build time.
            </p>
          </div>
          <div>
            <h3>Centralized Observability</h3>
            <p>
              Prometheus and Grafana stacks track telemetry across the fleet. Our dashboard monitors not just uptime, but "Blueprint Compliance"—flagging any node that differs from code.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .architecture-page {
      display: flex;
      flex-direction: column;
      gap: 6rem;
    }

    .header-container {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .header-container p {
      margin: 0 auto;
    }

    .badge {
      display: inline-block;
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.2);
      color: var(--accent-cyan);
      padding: 0.35rem 0.85rem;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .gradient-text {
      background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-blue) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      font-size: 1.25rem;
      line-height: 1.6;
    }

    /* Section Block Base */
    .section-block {
      padding: 2rem 0;
    }

    .grid-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 4rem;
    }

    .grid-layout.reversed {
      direction: rtl;
    }

    .grid-layout.reversed .text-pane {
      direction: ltr;
    }

    .grid-layout.reversed .visual-pane {
      direction: ltr;
    }

    .text-pane ul {
      list-style-type: none;
      margin-top: 1.5rem;
    }

    .text-pane li {
      margin-bottom: 1rem;
      position: relative;
      padding-left: 2rem;
      color: var(--text-muted);
    }

    .text-pane li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--accent-cyan);
      font-weight: bold;
    }

    .text-pane li strong {
      color: #ffffff;
    }

    /* Visual Pane Styles (CSS Flowcharts) */
    .visual-pane {
      display: flex;
      justify-content: center;
    }

    .flow-diagram {
      width: 100%;
      max-width: 400px;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem;
      gap: 0.75rem;
    }

    .flow-node {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      text-align: center;
      width: 100%;
    }

    .node-start {
      border-color: rgba(255, 255, 255, 0.2);
    }

    .node-process {
      border-color: var(--accent-indigo);
      background: rgba(99, 102, 241, 0.05);
    }

    .flow-arrow {
      color: var(--text-muted);
      font-size: 1.2rem;
    }

    .flow-split {
      display: flex;
      width: 100%;
      gap: 1.5rem;
    }

    .split-branch {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .end-cyan {
      border-color: var(--accent-cyan);
      color: var(--accent-cyan);
    }

    .end-blue {
      border-color: var(--accent-blue);
      color: var(--accent-blue);
    }

    /* Canopy Cards */
    .section-intro {
      text-align: center;
      margin-bottom: 4rem;
    }

    .section-intro p {
      margin: 0 auto;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.5rem;
    }

    .spec-card {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .spec-icon {
      font-size: 2rem;
    }

    .spec-card h3 {
      font-size: 1.25rem;
      color: #ffffff;
    }

    .spec-card p {
      font-size: 0.95rem;
      margin: 0;
    }

    /* Agent Ring Graphic */
    .agent-graphic {
      width: 320px;
      height: 320px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .agent-ring {
      position: relative;
      width: 200px;
      height: 200px;
      border: 2px dashed var(--border);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      /* animation: rotateRing 30s linear infinite; */
    }

    .agent-core {
      width: 80px;
      height: 80px;
      background: radial-gradient(circle, var(--accent-cyan) 0%, var(--accent-blue) 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      color: #000000;
      box-shadow: 0 0 30px rgba(6, 182, 212, 0.4);
      animation: pulseCore 3s ease-in-out infinite alternate;
    }

    .agent-node {
      position: absolute;
      width: 90px;
      height: 36px;
      background: #18181b;
      border: 1px solid var(--border);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.8rem;
      color: #ffffff;
      box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    .a-n1 { top: -18px; left: 55px; border-color: var(--accent-cyan); }
    .a-n2 { bottom: 10px; left: -25px; border-color: var(--accent-blue); }
    .a-n3 { bottom: 10px; right: -25px; border-color: var(--accent-indigo); }

    .agent-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .agent-item strong {
      display: block;
      font-size: 1.1rem;
      color: #ffffff;
      margin-bottom: 0.25rem;
    }

    .agent-item p {
      font-size: 0.95rem;
      margin: 0;
    }

    /* Detail Banner */
    .detail-banner {
      border-color: rgba(99, 102, 241, 0.3);
      padding: 3rem;
    }

    .detail-banner h2 {
      text-align: center;
      margin-bottom: 2rem;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .detail-grid h3 {
      font-size: 1.25rem;
      margin-bottom: 0.75rem;
      color: #ffffff;
    }

    .detail-grid p {
      font-size: 0.95rem;
      margin: 0;
    }

    /* Animations */
    @keyframes rotateRing {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes pulseCore {
      0% { transform: scale(1); box-shadow: 0 0 20px rgba(6, 182, 212, 0.3); }
      100% { transform: scale(1.05); box-shadow: 0 0 35px rgba(6, 182, 212, 0.5); }
    }

    /* Responsive Adaptation */
    @media (max-width: 992px) {
      .grid-layout {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }

      .grid-layout.reversed {
        direction: ltr;
      }

      .text-pane li {
        text-align: left;
      }

      .agent-graphic {
        margin: 0 auto;
      }

      .detail-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .architecture-page {
        gap: 4rem;
      }
    }
  </style>
</Layout>
